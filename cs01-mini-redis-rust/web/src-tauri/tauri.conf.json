{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CS01 mini-redis",
  "version": "0.1.0",
  "identifier": "dev.adsd-in-practice.cs01-mini-redis",
  "build": {
    "beforeDevCommand": "pnpm dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "CS01 mini-redis",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:6381 http://localhost:6381; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
